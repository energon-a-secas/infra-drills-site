# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── Playwright MCP (Claude Code browser automation — screenshots, logs) ───────
.playwright-mcp/

# ── Playwright test artifacts ─────────────────────────────────────────────────
test-results/
playwright-report/
blob-report/

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
package-lock.json

# ── LocalStack / Docker volume data (runtime state, not source) ──────────────
**/volume/*

# ── gitlab-ci-local temp data ─────────────────────────────────────────────────
**/.gitlab-ci-local/

# ── Secrets — never commit ────────────────────────────────────────────────────
.env
.env.*
