# ── Playwright MCP session data (screenshots and logs, not source code) ───────
.playwright-mcp/

# ── Playwright test artifacts ─────────────────────────────────────────────────
test-results/
playwright-report/
blob-report/

# ── Node dependencies ─────────────────────────────────────────────────────────
node_modules/
package-lock.json

# ── macOS metadata (binary, not useful to read) ───────────────────────────────
.DS_Store

# ── LocalStack / Docker volume data (runtime state, not source) ──────────────
**/volume/*

# ── gitlab-ci-local temp data ─────────────────────────────────────────────────
**/.gitlab-ci-local/
